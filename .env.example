# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartflow
DB_USER=smartflow_user
DB_PASSWORD=your_password_here

# OpenAI / LLM Annotation
OPENAI_API_KEY=your_openai_key_here

# Airflow
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://smartflow_user:your_password_here@localhost/airflow_db

# Spark
SPARK_MASTER=local[*]
JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
